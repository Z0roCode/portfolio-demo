# ---------------------------------------------------------------------------
# Z0roCode Estates — environment variables
# Copy this file to `.env` and adjust as needed.
# ---------------------------------------------------------------------------

# Prisma database connection.
#
# PRODUCTION (Vercel):
#   Use a hosted Postgres connection string.
#   Recommended free options:
#     - Supabase:          https://supabase.com (free 500MB, easiest — see README)
#     - Vercel Postgres:   https://vercel.com/docs/storage/vercel-postgres
#     - Neon:              https://neon.tech
#   Supabase pooled connection example (port 6543, add ?pgbouncer=true):
#     postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# LOCAL DEVELOPMENT:
#   Either use a local Postgres, OR use SQLite by temporarily setting the
#   provider in prisma/schema.prisma back to "sqlite" and using a file URL:
#   DATABASE_URL="file:./db/custom.db"
#
DATABASE_URL="postgresql://user:password@localhost:5432/z0rocode?schema=public"

# ---------------------------------------------------------------------------
# OPTIONAL — only needed if you want to pull fresh photos from Unsplash at
# seed time. The demo ships with a pre-seeded image set, so you can leave
# this blank and the site will still show real photography.
# Get a key at: https://unsplash.com/developers
# NEVER commit a real key. The demo never reads this at runtime.
# ---------------------------------------------------------------------------
# UNSPLASH_ACCESS_KEY=""
